# frozen_string_literal: true

# Cette source indique à Bundler où récupérer les gems Ruby.
source "https://rubygems.org"

# Cette gem permet d'analyser du HTML de manière propre et pratique.
gem "nokogiri"

# Cette gem permet de charger automatiquement les variables du fichier .env.
gem "dotenv"

# Cette gem permet d'écrire dans un Google Spreadsheet.
gem "google_drive"

# Cette gem sert à écrire et lancer les tests.
gem "rspec"
